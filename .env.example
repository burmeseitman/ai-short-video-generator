# ─────────────────────────────────────────────────────────────────────────────
# 🤖 AI Provider Settings (Text / Reasoning / Planner)
# ─────────────────────────────────────────────────────────────────────────────

# Model to use for CrewAI and Planner. Can be local (Ollama) or cloud (Gemini, OpenAI, etc.)
# Examples:
#   Local (Ollama)  → ollama/qwen2.5:14b  |  ollama/llama3.1
#   Google Gemini   → google/gemini-flash-latest  |  google/gemini-3.5-flash
#   OpenAI          → openai/gpt-4o-mini
AI_MODEL=ollama/qwen2.5:14b

# Dedicated model for scriptwriting and scene planning (Writer & Director agents).
# (Using local Qwen 2.5 to avoid API costs)
WRITER_MODEL=ollama/qwen2.5:14b

# Whether to render subtitles directly overlayed on the video.
# If True (default), subtitles are composited into the final video.
# If False, on-screen subtitles are disabled and a standalone subtitles.srt file is generated.
RENDER_SUBTITLES=True

# ─────────────────────────────────────────────────────────────────────────────
# 🎬 Free Stock Media API Keys
# ─────────────────────────────────────────────────────────────────────────────

# API key for Pexels Stock Video Search (https://www.pexels.com/api/)
PEXELS_API_KEY=YOUR_PEXELS_API_KEY

# API key for Unsplash Stock Image Search (https://unsplash.com/developers)
UNSPLASH_API_KEY=YOUR_UNSPLASH_API_KEY

# API key for GIPHY Stock GIF Search (https://developers.giphy.com/)
GIPHY_API_KEY=YOUR_GIPHY_API_KEY
